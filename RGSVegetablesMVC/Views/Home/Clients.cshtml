@{
    ViewData["Title"] = "Clients";
}

<section class="container section">
  <h1>Our Clients</h1>
  <p class="subtle">From cloud kitchens to retail counters — we supply consistent quality.</p>

  <div class="logo-cloud">
    <span class="logo-chip">Zomato</span>
    <span class="logo-chip">Swiggy</span>
    <span class="logo-chip">Reliance Fresh</span>
    <span class="logo-chip">Hotels & Caterers</span>
    <span class="logo-chip">Apartment Communities</span>
  </div>

  <section class="grid-2 highlight m-top">
    <figure class="card-image"><img src="https://images.unsplash.com/photo-1504754524776-8f4f37790ca0?q=80&w=1200&auto=format&fit=crop" alt="Chef prepping vegetables in a kitchen"></figure>
    <div>
      <h2>Service Levels</h2>
      <ul class="checks">
        <li>Daily delivery windows: 6–9 AM & 3–6 PM</li>
        <li>Bulk & standing orders with fixed schedules</li>
        <li>Transparent pricing with weekly rate sheets</li>
      </ul>
      <a class="btn" asp-controller="Home" asp-action="Contact">Request rate card</a>
    </div>
  </section>
</section>