@{
    ViewData["Title"] = "About";
}

<section class="container section grid-2 about">
  <figure class="card-image">
    <img onerror="this.onerror=null;this.src='data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='800' height='600'><rect width='100%' height='100%' fill='%23e8f2ec'/><text x='50%' y='50%' dominant-baseline='middle' text-anchor='middle' font-family='Arial' font-size='24' fill='%231f7a4c'>Image coming fresh!</text></svg>';" src="https://images.unsplash.com/photo-1485637701891-6bbed2b4bfa5?q=80&w=1200&auto=format&fit=crop" alt="Family farming in a field" />
  </figure>
  <div>
    <h1>Rooted in Hyderabad, grown by the Kavali family</h1>
    <p>RGS Vegetable Supplier is a family‑run farm and distribution network. What began as a small mandi stall has grown into a trusted supplier to homes, hotels, and retail chains in Hyderabad. We keep our process simple: harvest at dawn, grade & pack carefully, and deliver the same day.</p>
    <ul class="checks">
      <li>Clean and hygienic handling at every step</li>
      <li>Reliable logistics across Moosapet, Shankarpally, Patancheru & Moinabad</li>
      <li>Flexible order sizes — from 5 kg to multi‑tonne consignments</li>
    </ul>
    <div class="badges">
      <span class="badge">Retail & Wholesale</span>
      <span class="badge">Pan‑city routes</span>
      <span class="badge">Family‑owned</span>
    </div>
  </div>
</section>

<section class="container section highlight">
  <h2>Our Coverage Areas</h2>
  <div class="chips">
    <span class="chip">Moosapet, Hyderabad</span>
    <span class="chip">Shankarpally, RR Dist</span>
    <span class="chip">Patancheru, Sangareddy Dist</span>
    <span class="chip">Moinabad, RR Dist</span>
  </div>
</section>